{
  "name": "latentspacelabs-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Latent Space Labs monorepo. Docs under docs/, owned TypeScript packages under packages/.",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "validate:adrs": "node packages/adr-tools/dist/cli.js docs/decisions",
    "validate:prds": "node packages/prd-tools/dist/cli.js docs/prds",
    "policy-scan": "node packages/policy-scanner/dist/cli.js .",
    "secret-guard": "node packages/secret-guard/dist/cli.js",
    "secret-guard:staged": "node packages/secret-guard/dist/cli.js --staged",
    "secret-guard:install-hook": "node packages/secret-guard/dist/install-hook.js",
    "check": "npm run typecheck && npm run build && npm run validate:adrs && npm run validate:prds && npm run policy-scan && npm run test"
  }
}
